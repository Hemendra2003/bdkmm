From a5106aa5f756ef25c4f6c558056f8d6567f524d2 Mon Sep 17 00:00:00 2001
From: Claude <claude@local>
Date: Wed, 17 Jun 2026 12:17:33 +0000
Subject: [PATCH] flip graph fill gradient: full opacity at top, transparent at
 bottom

---
 index.html | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/index.html b/index.html
index 14995ae..60b0df5 100644
--- a/index.html
+++ b/index.html
@@ -1111,9 +1111,9 @@ function renderLineGraph(svgId, tooltipId, points, opts){
   const grad=mk('linearGradient',{id:svgId+'_grad',x1:'0',y1:PAD_T,x2:'0',y2:baseY,gradientUnits:'userSpaceOnUse'});
   const fillCol=opts&&opts.fillColor?opts.fillColor:'rgba(255,184,48,1)';
   const fillBase=fillCol.replace(/[\d.]+\)$/,'');
-  grad.appendChild(mk('stop',{offset:'0%','stop-color':fillBase+'0.04)'}));
-  grad.appendChild(mk('stop',{offset:'55%','stop-color':fillBase+'0.22)'}));
-  grad.appendChild(mk('stop',{offset:'100%','stop-color':fillBase+'0.55)'}));
+  grad.appendChild(mk('stop',{offset:'0%','stop-color':fillBase+'0.55)'}));
+  grad.appendChild(mk('stop',{offset:'45%','stop-color':fillBase+'0.22)'}));
+  grad.appendChild(mk('stop',{offset:'100%','stop-color':fillBase+'0.04)'}));
   defs.appendChild(grad);svg.appendChild(defs);
 
   const segments=[];let cur=[];
-- 
2.43.0

