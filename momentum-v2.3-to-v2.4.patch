From 5030985536dda2f87588806305e69f3287446e00 Mon Sep 17 00:00:00 2001
From: Claude <claude@local>
Date: Wed, 17 Jun 2026 11:57:24 +0000
Subject: [PATCH] v2.4: unify three hero badges into matching pill style, warm
 amber color, fix thunder icon size/placement to right of count

---
 index.html | 29 ++++++++++++++---------------
 1 file changed, 14 insertions(+), 15 deletions(-)

diff --git a/index.html b/index.html
index 0969bb3..e1086ef 100644
--- a/index.html
+++ b/index.html
@@ -91,22 +91,22 @@ body{margin:0;padding:0;width:100vw;max-width:100%;height:100vh}
   text-shadow:0 0 40px rgba(255,184,48,.75),0 0 80px rgba(255,184,48,.3),4px 4px 0 rgba(120,70,0,.45);
 }
 .velocity-unit-center{font-family:var(--mono);font-size:11px;color:var(--slate2);letter-spacing:.25em;text-align:center;margin-top:6px}
-.multiplier-pill{
-  display:inline-flex;align-items:center;gap:5px;
-  font-family:var(--mono);font-size:10px;color:var(--silver);letter-spacing:.06em;
-  background:rgba(184,184,208,.06);border:1px solid rgba(184,184,208,.18);
-  padding:3px 10px;border-radius:3px;
+.h-badge-pill{
+  display:inline-flex;align-items:center;justify-content:center;gap:6px;
+  background:rgba(255,200,100,.08);border:1px solid rgba(255,200,100,.22);
+  padding:5px 13px;border-radius:5px;min-height:28px;
 }
+.h-badge-pill span:not(.mult-dot){font-family:var(--pixel);font-size:13px;line-height:1;color:#FFC864}
+.badge-emoji{font-family:initial;font-size:13px;margin-left:5px;vertical-align:-1px;display:inline-block}
 @keyframes mpulse{0%,100%{opacity:1}50%{opacity:0}}
-.mult-dot{width:4px;height:4px;background:var(--silver);border-radius:50%;display:inline-block;animation:mpulse 1.2s steps(2) infinite;flex-shrink:0}
+.mult-dot{width:4px;height:4px;background:#FFC864;border-radius:50%;display:inline-block;animation:mpulse 1.2s steps(2) infinite;flex-shrink:0}
 
 /* hero badges row */
 .hero-badges{
   display:flex;align-items:center;justify-content:center;gap:24px;
   margin-top:16px;
 }
-.h-badge{display:flex;flex-direction:column;align-items:center;gap:3px}
-.h-badge-num{font-family:var(--pixel);font-size:14px;line-height:1;color:var(--silver)}
+.h-badge{display:flex;flex-direction:column;align-items:center;gap:6px}
 .h-badge-label{font-family:var(--mono);font-size:8px;color:var(--slate2);letter-spacing:.12em;text-transform:uppercase}
 .h-badge-sep{width:1px;height:28px;background:var(--bg3)}
 
@@ -499,17 +499,17 @@ body{margin:0;padding:0;width:100vw;max-width:100%;height:100vh}
       <!-- badges row -->
       <div class="hero-badges">
         <div class="h-badge" id="delta-badge" style="display:none">
-          <div class="h-badge-num" id="delta-badge-num">—</div>
+          <div class="h-badge-pill"><span id="delta-badge-num">—</span></div>
           <div class="h-badge-label">VS YESTERDAY</div>
         </div>
         <div class="h-badge-sep" id="badge-sep-1" style="display:none"></div>
         <div class="h-badge" id="streak-badge">
-          <div class="h-badge-num" id="streak-badge-num">—</div>
+          <div class="h-badge-pill"><span id="streak-badge-num">—</span></div>
           <div class="h-badge-label" id="streak-badge-label">STREAK</div>
         </div>
         <div class="h-badge-sep" id="badge-sep-2"></div>
         <div class="h-badge">
-          <div class="multiplier-pill"><span class="mult-dot"></span><span id="mult-text">—</span></div>
+          <div class="h-badge-pill"><span class="mult-dot"></span><span id="mult-text">—</span></div>
           <div class="h-badge-label">MULTIPLIER</div>
         </div>
       </div>
@@ -1244,7 +1244,6 @@ function renderDashboard(cache){
       document.getElementById('badge-sep-1').style.display='block';
       const dn=document.getElementById('delta-badge-num');
       dn.textContent=(diff>=0?'+':'-')+Math.abs(diff);
-      dn.className='h-badge-num';
     }
     document.getElementById('mult-text').textContent=c.mult+'×';
     renderStreakBadge(c.posStreak||0,c.negStreak||0);
@@ -1299,11 +1298,11 @@ function renderStreakBadge(posS,negS){
   const numEl=document.getElementById('streak-badge-num');
   const lblEl=document.getElementById('streak-badge-label');
   if(posS>0){
-    numEl.textContent='⚡'+posS;numEl.className='h-badge-num';lblEl.textContent='DAY STREAK';
+    numEl.innerHTML=posS+'<span class="badge-emoji">⚡</span>';lblEl.textContent='DAY STREAK';
   } else if(negS>0){
-    numEl.textContent='⚡'+negS;numEl.className='h-badge-num';lblEl.textContent='DAY DRAG';
+    numEl.innerHTML=negS+'<span class="badge-emoji">⚡</span>';lblEl.textContent='DAY DRAG';
   } else {
-    numEl.textContent='—';numEl.className='h-badge-num';lblEl.textContent='STREAK';
+    numEl.textContent='—';lblEl.textContent='STREAK';
   }
 }
 
-- 
2.43.0

