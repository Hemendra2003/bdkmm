+  border-radius:6px;
+}
+@keyframes skelshim{0%{background-position:200% 0}100%{background-position:-200% 0}}
+.skel-header{width:100%;height:18px;margin-bottom:38px}
+.skel-rocket{width:88px;height:120px;border-radius:12px;margin-bottom:14px}
+.skel-eyebrow{width:140px;height:10px;margin-bottom:14px}
+.skel-score{width:200px;height:58px;margin-bottom:10px;border-radius:10px}
+.skel-unit{width:80px;height:10px;margin-bottom:20px}
+.skel-badges-row{display:flex;gap:18px;margin-bottom:24px}
+.skel-pill{width:64px;height:30px}
+.skel-btn{width:100%;height:48px;margin-bottom:28px}
+.skel-graph{width:100%;height:130px;margin-bottom:24px}
+#dashboard-content.is-loading > *:not(#dashboard-skeleton){visibility:hidden}
+@media(prefers-reduced-motion:reduce){.skel-row,.skel-pill,.skel-rocket{animation:none}}
+
