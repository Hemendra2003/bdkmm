+/* DASHBOARD SKELETON — shown until first data load resolves */
+#dashboard-content{position:relative}
+.skeleton-wrap{
+  display:none;
+  position:absolute;inset:0;z-index:50;
+  background:var(--bg);
+  flex-direction:column;align-items:center;
+  padding:24px 20px 0;
+}
+#dashboard-content.is-loading .skeleton-wrap{display:flex}
+.skel-row,.skel-pill,.skel-rocket{
+  background:linear-gradient(100deg,var(--bg2) 30%,var(--bg3) 50%,var(--bg2) 70%);
