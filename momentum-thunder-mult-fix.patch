From c615e832855217c7a23d93ffe26965e112e511bd Mon Sep 17 00:00:00 2001
From: Claude <claude@local>
Date: Wed, 17 Jun 2026 12:09:44 +0000
Subject: [PATCH] thunder emoji back (yellow, aligned with day count via flex
 row), fix multiplier dot rendering above text instead of beside it

---
 index.html | 10 ++++++----
 1 file changed, 6 insertions(+), 4 deletions(-)

diff --git a/index.html b/index.html
index ac8d6f8..d354e5b 100644
--- a/index.html
+++ b/index.html
@@ -92,9 +92,11 @@ body{margin:0;padding:0;width:100vw;max-width:100%;height:100vh}
 }
 .velocity-unit-center{font-family:var(--mono);font-size:11px;color:var(--slate2);letter-spacing:.25em;text-align:center;margin-top:6px}
 .h-badge span:not(.mult-dot){font-family:var(--pixel);font-size:13px;line-height:1;color:var(--green);text-shadow:0 0 10px rgba(61,255,110,.35)}
-.badge-emoji{font-family:initial;font-size:13px;margin-left:5px;vertical-align:-1px;display:inline-block}
+.h-badge-num-row{display:inline-flex;align-items:center;gap:5px}
+.badge-emoji{font-size:14px;display:inline-flex;align-items:center;line-height:1;filter:sepia(1) saturate(6) hue-rotate(2deg) brightness(1.1)}
 @keyframes mpulse{0%,100%{opacity:1}50%{opacity:0}}
 .mult-dot{width:4px;height:4px;background:var(--green);border-radius:50%;display:inline-block;animation:mpulse 1.2s steps(2) infinite;flex-shrink:0}
+.mult-row{display:inline-flex;align-items:center;gap:5px}
 
 /* hero badges row */
 .hero-badges{
@@ -504,7 +506,7 @@ body{margin:0;padding:0;width:100vw;max-width:100%;height:100vh}
         </div>
         <div class="h-badge-sep" id="badge-sep-2"></div>
         <div class="h-badge">
-          <span class="mult-dot"></span><span id="mult-text">—</span>
+          <div class="mult-row"><span class="mult-dot"></span><span id="mult-text">—</span></div>
           <div class="h-badge-label">MULTIPLIER</div>
         </div>
       </div>
@@ -1293,9 +1295,9 @@ function renderStreakBadge(posS,negS){
   const numEl=document.getElementById('streak-badge-num');
   const lblEl=document.getElementById('streak-badge-label');
   if(posS>0){
-    numEl.innerHTML=posS+'<span class="badge-emoji">🔥</span>';lblEl.textContent='DAY STREAK';
+    numEl.innerHTML='<span class="h-badge-num-row">'+posS+'<span class="badge-emoji">⚡</span></span>';lblEl.textContent='DAY STREAK';
   } else if(negS>0){
-    numEl.innerHTML=negS+'<span class="badge-emoji">🔥</span>';lblEl.textContent='DAY DRAG';
+    numEl.innerHTML='<span class="h-badge-num-row">'+negS+'<span class="badge-emoji">⚡</span></span>';lblEl.textContent='DAY DRAG';
   } else {
     numEl.textContent='—';lblEl.textContent='STREAK';
   }
-- 
2.43.0

