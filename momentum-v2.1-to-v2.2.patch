Subject: [PATCH] v2.2: snappier auto-advance (160ms), blue close button, trim
 unlogged-today from graphs, resume keeps full 1/15 navigation

---
 index.html | 44 +++++++++++++++++++++++++-------------------
 1 file changed, 25 insertions(+), 19 deletions(-)

diff --git a/index.html b/index.html
index ebd3563..d72c675 100644
--- a/index.html
+++ b/index.html
@@ -664,7 +664,7 @@ body{margin:0;padding:0;width:100vw;max-width:100%;height:100vh}
     <div class="line-graph-wrap" style="margin-bottom:4px">
       <svg id="sum-week-line-svg" class="line-graph-svg" height="120"></svg>
     </div>
-    <button class="btn btn-primary-red" onclick="closeSummaryToHome()" style="margin:24px 0">Back to Dashboard</button>
+    <button class="btn btn-primary-blue" onclick="closeSummaryToHome()" style="margin:24px 0">Back to Dashboard</button>
   </div>
 </div>
 
@@ -819,21 +819,22 @@ function toggleDevTools(){
 // QUESTIONNAIRE — open instantly
 // ══════════════════════════════════
 let currentQ=0,answers={},savedAnswers={};
-let activeQueue=[];   // indices into QS that are actually shown this session
-let _resumeMode=false; // true = skip already-answered (begin/resume flow); false = show all (update flow)
+let activeQueue=[];   // always all 15 question indices, in order
+let _resumeMode=false; // true = jump to first unanswered on open (begin/resume flow); false = stay at 0 (update flow)
 
-function buildQueue(skipAnswered){
-  if(skipAnswered){
-    const q=QS.map((_,i)=>i).filter(i=>answers[QS[i].key]===undefined);
-    return q.length?q:QS.map((_,i)=>i);
+function buildQueue(){return QS.map((_,i)=>i);}
+
+function firstUnansweredIdx(){
+  for(let i=0;i<activeQueue.length;i++){
+    if(answers[QS[activeQueue[i]].key]===undefined) return i;
   }
-  return QS.map((_,i)=>i);
+  return 0; // all answered — start from the top
 }
 
 function openLog(){
   // Show overlay immediately — don't wait for network
   answers={};savedAnswers={};_resumeMode=true;
-  activeQueue=buildQueue(false); // until we know if there's a partial, show all
+  activeQueue=buildQueue();
   currentQ=0;
   document.getElementById('questionnaire').classList.add('active');
   renderQ();
@@ -841,8 +842,7 @@ function openLog(){
     const te=cache[todayKey()];
     if(te&&te.answers){
       answers={...te.answers};savedAnswers={...te.answers};
-      activeQueue=buildQueue(true); // skip already-answered ones
-      currentQ=0;
+      currentQ=firstUnansweredIdx(); // jump to first unanswered, but full 1-15 stays navigable
       renderQ();
     }
   }).catch(()=>{});
@@ -853,7 +853,7 @@ function openLogFullEdit(){
   answers={};savedAnswers={};_resumeMode=false;
   currentQ=0;
   document.getElementById('questionnaire').classList.add('active');
-  activeQueue=buildQueue(false);
+  activeQueue=buildQueue();
   renderQ();
   loadCache().then(cache=>{
     const te=cache[todayKey()];
@@ -911,7 +911,7 @@ function selectAnswer(idx){
     _advanceTimer=null;
     if(currentQ<activeQueue.length-1){currentQ++;renderQ();}
     else finishQuestionnaire();
-  },350);
+  },160);
 }
 
 function goBack(){clearAdvanceTimer();if(currentQ>0){currentQ--;renderQ();}}
@@ -1090,10 +1090,13 @@ function renderLineGraph(svgId, tooltipId, points, opts){
 
 // WEEK LINE GRAPH (Δv, last 7 days)
 function renderWeekLineGraph(cache){
-  const days=[];for(let i=6;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);days.push(d.toISOString().slice(0,10));}
-  const DN=['SUN','MON','TUE','WED','THU','FRI','SAT'];
   const tk=todayKey();
-  const points=days.map(k=>({
+  const hasToday=!!(cache[tk]&&cache[tk].computed);
+  const span=hasToday?7:8; // pull one extra day back so we still show 7 *logged* days when today is empty
+  const days=[];for(let i=span-1;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);days.push(d.toISOString().slice(0,10));}
+  const trimmed=hasToday?days:days.filter(k=>k!==tk).slice(-7);
+  const DN=['SUN','MON','TUE','WED','THU','FRI','SAT'];
+  const points=trimmed.map(k=>({
     label:DN[new Date(k+'T12:00:00').getDay()],
     value:(cache[k]&&cache[k].computed)?cache[k].computed.finalDv:null,
     isToday:k===tk,
@@ -1113,11 +1116,14 @@ function renderMonthLineGraph(cache){
     spanDays=Math.max(1,Math.min(30,daysSinceEarliest));
   }
   const days=[];for(let i=spanDays-1;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);days.push(d.toISOString().slice(0,10));}
-  const labelEvery=spanDays<=7?1:spanDays<=14?2:5;
-  const points=days.map((k,i)=>{
+  const hasToday=!!(cache[tk]&&cache[tk].computed);
+  let trimmedDays=hasToday?days:days.filter(k=>k!==tk);
+  if(trimmedDays.length===0) trimmedDays=days; // fallback: nothing logged yet at all
+  const labelEvery=trimmedDays.length<=7?1:trimmedDays.length<=14?2:5;
+  const points=trimmedDays.map((k,i)=>{
     const d=new Date(k+'T12:00:00');
     const dayNum=d.getDate();
-    const showLabel=i===0||i===days.length-1||i%labelEvery===0||k===tk;
+    const showLabel=i===0||i===trimmedDays.length-1||i%labelEvery===0||k===tk;
     return{
       label:showLabel?String(dayNum):'',
       value:(cache[k]&&cache[k].computed)?cache[k].computed.newVelocity:null,
-- 
